---
// The single hydration island for the whole map (docs/ARCHITECTURE.md
// section 2, ADR-0001). Server-rendered output is inert: a canvas, a
// no-JS-required fallback link into Atlas, and the loading status FR002
// requires. No Three.js code ships with the initial page load; the inline
// bootstrap script below only performs a dynamic import() once WebGL
// support is confirmed (AC034, the lazy boundary). The canvas is aria-hidden
// decoration (docs/ACCESSIBILITY.md section 6): the Atlas route and the
// permanent ATLAS control here are the real accessible surface for the
// catalog, not this component.
import { sectorsSchema } from '@lib/catalog/schema';
import sectorsRaw from '@data/sectors.json';

const sectors = sectorsSchema
  .parse(sectorsRaw)
  .sectors.slice()
  .sort((a, b) => a.order - b.order);
---

<!--
  Two separate fixed layers, not one, because they need to sit on opposite
  sides of the hero shell in paint order and CSS stacking cannot straddle
  that from a single ancestor:
  - galaxy-backdrop (z-index: -1) paints behind the static hero content, so
    the canvas never covers the hero text.
  - galaxy-stage (no negative z-index; pointer-events: none at the container
    level with auto re-enabled per control, see global.css) paints above the
    hero so its controls stay reachable, while empty space around them still
    passes clicks through to the canvas beneath.
  A single wrapper with z-index: -1 would bury its *entire* subtree,
  including these controls, behind <body>'s own full-viewport box, which
  still intercepts pointer events even though it paints nothing there.
-->
<div class="galaxy-backdrop" id="galaxy-backdrop">
  <canvas
    class="galaxy-canvas"
    id="galaxy-canvas"
    aria-hidden="true"
    tabindex="-1"></canvas>
  <div class="galaxy-label-host" id="galaxy-label-host" aria-hidden="true">
  </div>
</div>

<div class="galaxy-stage" id="galaxy-stage" data-map-state="loading">
  <div class="galaxy-fallback" id="galaxy-fallback" hidden>
    <p class="mono-meta">Map unavailable on this device</p>
    <p class="hero-support">
      The interactive star map needs WebGL, which this browser or device does
      not currently support. The complete catalog is still fully available.
    </p>
    <a class="btn btn-primary" href="/atlas/">Open the Atlas</a>
  </div>

  <div class="galaxy-hud" id="galaxy-hud">
    <ul
      class="galaxy-boot-states"
      id="galaxy-boot-states"
      data-testid="galaxy-boot-states"
    >
      <li data-state="catalog-loading">Catalog loaded</li>
      <li data-state="renderer-ready">Renderer ready</li>
      <li data-state="labels-ready">Labels ready</li>
      <li data-state="online">Map online</li>
    </ul>
    <button
      type="button"
      class="btn btn-tertiary galaxy-skip"
      id="galaxy-skip"
      data-testid="galaxy-skip"
    >
      Skip
    </button>
  </div>

  <div class="galaxy-controls">
    <button
      type="button"
      class="btn btn-secondary galaxy-surprise"
      id="galaxy-surprise"
      data-testid="galaxy-surprise"
      hidden
    >
      Surprise Me
    </button>
    <a
      class="btn btn-secondary galaxy-atlas-link"
      href="/atlas/"
      data-testid="galaxy-atlas-link"
    >
      Atlas
    </a>
    <button
      type="button"
      class="btn btn-secondary galaxy-pause"
      id="galaxy-pause"
      data-testid="galaxy-pause"
      aria-pressed="false"
      hidden
    >
      Pause Motion
    </button>
  </div>

  <div
    class="galaxy-filter-rail"
    id="galaxy-filter-rail"
    role="group"
    aria-label="Filter the map by sector"
    hidden
  >
    {
      sectors.map((sector) => (
        <button
          type="button"
          class="galaxy-filter"
          data-map-filter={sector.id}
          aria-pressed="false"
        >
          {sector.mapLabel}
        </button>
      ))
    }
    <span
      class="mono-note galaxy-filter-count"
      id="galaxy-filter-count"
      data-testid="galaxy-filter-count"></span>
  </div>

  <p
    class="galaxy-readout mono-meta"
    id="galaxy-readout"
    data-testid="galaxy-readout"
    aria-hidden="true"
  >
  </p>

  <div
    class="galaxy-tour"
    id="galaxy-tour"
    data-testid="galaxy-tour"
    role="group"
    aria-label="Guided tour"
    hidden
  >
    <p class="mono-note galaxy-tour__meta" id="galaxy-tour-meta"></p>
    <p class="galaxy-tour__narration" id="galaxy-tour-narration"></p>
    <div class="galaxy-tour__controls">
      <button
        type="button"
        class="btn btn-secondary"
        id="galaxy-tour-prev"
        data-testid="tour-prev">Back</button
      >
      <button
        type="button"
        class="btn btn-primary"
        id="galaxy-tour-next"
        data-testid="tour-next">Next</button
      >
      <button
        type="button"
        class="btn btn-tertiary"
        id="galaxy-tour-exit"
        data-testid="tour-exit">Exit tour</button
      >
    </div>
  </div>

  <div
    class="galaxy-palette"
    id="galaxy-palette"
    data-testid="galaxy-palette"
    role="dialog"
    aria-modal="true"
    aria-label="Command palette"
    hidden
  >
    <div class="galaxy-palette__box">
      <input
        type="text"
        class="galaxy-palette__input"
        id="galaxy-palette-input"
        data-testid="palette-input"
        placeholder="Search projects, tours, commands..."
        aria-label="Search projects, tours, and commands"
        autocomplete="off"
      />
      <ul
        class="galaxy-palette__results"
        id="galaxy-palette-results"
        role="listbox"
        aria-label="Results"
      >
      </ul>
    </div>
  </div>

  <aside
    class="galaxy-panel"
    id="galaxy-panel"
    data-testid="galaxy-panel"
    aria-labelledby="galaxy-panel-title"
    hidden
  >
    <div class="galaxy-panel__grab" aria-hidden="true"></div>
    <p class="mono-meta galaxy-panel__status" id="galaxy-panel-status"></p>
    <h2 class="galaxy-panel__title" id="galaxy-panel-title"></h2>
    <p class="galaxy-panel__desc" id="galaxy-panel-desc"></p>
    <ul
      class="galaxy-panel__related"
      id="galaxy-panel-related"
      aria-label="Related projects"
    >
    </ul>
    <div
      class="galaxy-panel__compare"
      id="galaxy-panel-compare-result"
      data-testid="compare-result"
      hidden
    >
    </div>
    <div class="galaxy-panel__actions">
      <a
        class="btn btn-primary"
        id="galaxy-panel-open"
        data-testid="panel-open-project"
        target="_blank"
        rel="noopener noreferrer">Open Project</a
      >
      <a class="btn btn-secondary" id="galaxy-panel-page" href="#"
        >Project Page</a
      >
      <button
        type="button"
        class="btn btn-secondary"
        id="galaxy-panel-compare"
        data-testid="panel-compare">Compare</button
      >
      <button
        type="button"
        class="btn btn-secondary"
        id="galaxy-panel-pin"
        data-testid="panel-pin"
        aria-pressed="false">Pin</button
      >
      <button
        type="button"
        class="btn btn-secondary"
        id="galaxy-panel-share"
        data-testid="panel-share">Share</button
      >
      <button
        type="button"
        class="btn btn-tertiary"
        id="galaxy-panel-close"
        data-testid="panel-close">Close</button
      >
    </div>
  </aside>
</div>

<script>
  import type {
    GalaxyController as GalaxyControllerType,
    MapState,
  } from '../../lib/graph/controller';
  import {
    readSlugFromUrl,
    writeSlugToUrl,
    onSlugPop,
  } from '../../lib/state/deepLink';

  const stage = document.getElementById('galaxy-stage')!;
  const canvas = document.getElementById('galaxy-canvas') as HTMLCanvasElement;
  const fallback = document.getElementById('galaxy-fallback')!;
  const hud = document.getElementById('galaxy-hud')!;
  const bootStates = document.getElementById('galaxy-boot-states')!;
  const skipButton = document.getElementById(
    'galaxy-skip',
  ) as HTMLButtonElement;
  const pauseButton = document.getElementById(
    'galaxy-pause',
  ) as HTMLButtonElement;
  const readout = document.getElementById('galaxy-readout')!;
  const labelHost = document.getElementById('galaxy-label-host')!;
  const panel = document.getElementById('galaxy-panel')!;
  const panelStatus = document.getElementById('galaxy-panel-status')!;
  const panelTitle = document.getElementById('galaxy-panel-title')!;
  const panelDesc = document.getElementById('galaxy-panel-desc')!;
  const panelRelated = document.getElementById('galaxy-panel-related')!;
  const panelOpen = document.getElementById(
    'galaxy-panel-open',
  ) as HTMLAnchorElement;
  const panelPage = document.getElementById(
    'galaxy-panel-page',
  ) as HTMLAnchorElement;
  const panelClose = document.getElementById(
    'galaxy-panel-close',
  ) as HTMLButtonElement;

  const reducedMotionQuery = window.matchMedia(
    '(prefers-reduced-motion: reduce)',
  );

  function detectWebgl(): boolean {
    try {
      const probe = document.createElement('canvas');
      return Boolean(
        probe.getContext('webgl2') ||
        probe.getContext('webgl') ||
        probe.getContext('experimental-webgl'),
      );
    } catch {
      return false;
    }
  }

  function showFallback(): void {
    stage.dataset.mapState = 'fallback';
    canvas.style.display = 'none';
    hud.style.display = 'none';
    fallback.hidden = false;
  }

  function hideEntranceOverlay(instant: boolean): void {
    const delay = instant || reducedMotionQuery.matches ? 0 : 450;
    window.setTimeout(() => {
      bootStates.classList.add('is-dismissed');
      skipButton.hidden = true;
    }, delay);
  }

  let controller: GalaxyControllerType | null = null;

  async function boot(): Promise<void> {
    if (!detectWebgl()) {
      showFallback();
      return;
    }

    skipButton.addEventListener('click', () => {
      controller?.skipEntrance();
      hideEntranceOverlay(true);
    });

    // "ENTER THE MAP" in the hero shell dismisses the entrance chrome too;
    // it is a real action now rather than a dead link into a future phase.
    for (const el of document.querySelectorAll('[data-action="enter-map"]')) {
      el.addEventListener('click', (event) => {
        event.preventDefault();
        controller?.skipEntrance();
        hideEntranceOverlay(true);
      });
    }

    pauseButton.addEventListener('click', () => {
      const paused = pauseButton.getAttribute('aria-pressed') === 'true';
      pauseButton.setAttribute('aria-pressed', String(!paused));
      controller?.setMotionPaused(!paused);
    });

    reducedMotionQuery.addEventListener('change', (event) => {
      controller?.setReducedMotion(event.matches);
    });

    try {
      const { GalaxyController } = await import('../../lib/graph/controller');
      controller = new GalaxyController();
      await controller.init(canvas, {
        labelHost,
        reducedMotion: reducedMotionQuery.matches,
        onStateChange: (state: MapState) => {
          stage.dataset.mapState = state;
          const item = bootStates.querySelector(`[data-state="${state}"]`);
          item?.classList.add('is-done');
          if (state === 'renderer-ready') pauseButton.hidden = false;
          if (state === 'online') {
            hideEntranceOverlay(false);
            filterRail.hidden = false;
            surpriseButton.hidden = false;
          }
        },
        onHover: (change) => {
          if (change.slug) readout.textContent = `HOVER // ${change.slug}`;
          else if (!readout.dataset.selected) readout.textContent = '';
        },
        onSelect: (change) => {
          readout.dataset.selected = change.slug ?? '';
          readout.textContent = change.slug ? `SELECTED // ${change.slug}` : '';
          applySelection(change.slug);
        },
        onTour: (state) => {
          if (!state.tourId) {
            tourBar.hidden = true;
            return;
          }
          tourBar.hidden = false;
          tourMeta.textContent = `${state.title} // STOP ${state.step + 1} OF ${state.total}`;
          tourNarration.textContent = state.narration ?? '';
          tourPrevBtn.disabled = state.step <= 0;
          tourNextBtn.textContent = state.atEnd ? 'Finish' : 'Next';
        },
        onFallback: () => showFallback(),
      });
    } catch {
      showFallback();
    }
  }

  // ------------------------------------------------------------------
  // Selection panel, deep links, history, and keyboard (Phase 3b:
  // FR015-FR022, AC015, AC016, AR003, AR004).
  // ------------------------------------------------------------------
  let lastInvoker: HTMLElement | null = null;
  let suppressUrlWrite = false;

  function applySelection(slug: string | null): void {
    // Compare mode intercept: an armed compare resolves the path to the newly
    // selected project rather than reframing the panel to it.
    if (compareArmed && compareFrom && slug && slug !== compareFrom) {
      const path = controller?.compareWith(compareFrom, slug);
      renderCompareResult(compareFrom, slug, path ?? null);
      compareArmed = false;
      panelCompare.textContent = 'Clear comparison';
      panelCompare.setAttribute('aria-pressed', 'true');
      return;
    }
    if (!suppressUrlWrite) writeSlugToUrl(slug);
    if (!slug) {
      if (!panel.hidden) {
        panel.hidden = true;
        // AR004: focus returns to the initiating control when the panel
        // closes; the canvas region is not focusable, so fall back to the
        // Atlas control which is always visible.
        (
          lastInvoker ??
          document.querySelector<HTMLElement>(
            '[data-testid="galaxy-atlas-link"]',
          )
        )?.focus();
      }
      return;
    }
    const node = controller?.getNode(slug);
    if (!node) return;
    const edges = controller?.getEdgesFor(slug) ?? [];

    const statusParts = [`SECTOR: ${node.sector.toUpperCase()}`];
    if (node.status) statusParts.push(`STATUS: ${node.status.toUpperCase()}`);
    if (node.anchor) statusParts.push('ANCHOR');
    statusParts.push(`REL: ${edges.length}`);
    panelStatus.textContent = statusParts.join(' // ');
    panelTitle.textContent = node.title;
    panelDesc.textContent = node.desc;
    panelOpen.href = node.url;
    panelPage.href = `/project/${node.slug}/`;

    panelRelated.textContent = '';
    for (const edge of edges) {
      const otherSlug = edge.source === slug ? edge.target : edge.source;
      const other = controller?.getNode(otherSlug);
      if (!other) continue;
      const li = document.createElement('li');
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'galaxy-panel__related-link';
      btn.textContent = other.title;
      btn.addEventListener('click', () => controller?.select(otherSlug));
      const reason = document.createElement('span');
      reason.className = 'galaxy-panel__reason';
      reason.textContent = edge.reason ?? '';
      li.append(btn, reason);
      panelRelated.append(li);
    }

    // Pin state (FR057, FR058): session-only, no account, never leaves the
    // browser tab.
    panelPin.setAttribute('aria-pressed', String(pinnedSlugs.has(slug)));
    panelPin.textContent = pinnedSlugs.has(slug) ? 'Pinned' : 'Pin';

    const wasHidden = panel.hidden;
    panel.hidden = false;
    if (wasHidden) {
      lastInvoker = (document.activeElement as HTMLElement) ?? null;
      // AR004: focus moves into the panel when it opens.
      panelClose.focus();
    }
  }

  const panelPin = document.getElementById(
    'galaxy-panel-pin',
  ) as HTMLButtonElement;
  const panelShare = document.getElementById(
    'galaxy-panel-share',
  ) as HTMLButtonElement;
  const pinnedSlugs = new Set<string>(
    JSON.parse(sessionStorage.getItem('galaxy-pins') ?? '[]') as string[],
  );

  panelPin.addEventListener('click', () => {
    const slug = controller?.getSelectedSlug();
    if (!slug) return;
    if (pinnedSlugs.has(slug)) pinnedSlugs.delete(slug);
    else pinnedSlugs.add(slug);
    sessionStorage.setItem('galaxy-pins', JSON.stringify([...pinnedSlugs]));
    panelPin.setAttribute('aria-pressed', String(pinnedSlugs.has(slug)));
    panelPin.textContent = pinnedSlugs.has(slug) ? 'Pinned' : 'Pin';
  });

  panelShare.addEventListener('click', async () => {
    // FR060: copy a stable link for the active project state.
    const link = window.location.href;
    try {
      await navigator.clipboard.writeText(link);
      panelShare.textContent = 'Copied';
      window.setTimeout(() => {
        panelShare.textContent = 'Share';
      }, 1500);
    } catch {
      // Clipboard blocked (permissions or insecure context): fall back to
      // selecting the URL so the visitor can copy manually.
      panelShare.textContent = 'Copy from address bar';
      window.setTimeout(() => {
        panelShare.textContent = 'Share';
      }, 2500);
    }
  });

  panelClose.addEventListener('click', () => {
    exitCompareMode();
    controller?.select(null);
  });

  // Compare mode (FR035, FR036): Compare arms a pick-a-second-project state;
  // the next selection resolves the shortest meaningful path, explained hop
  // by hop, or reports honestly that no typed path exists.
  const panelCompare = document.getElementById(
    'galaxy-panel-compare',
  ) as HTMLButtonElement;
  const compareResult = document.getElementById('galaxy-panel-compare-result')!;
  let compareArmed = false;
  let compareFrom: string | null = null;

  function exitCompareMode(): void {
    compareArmed = false;
    compareFrom = null;
    compareResult.hidden = true;
    compareResult.textContent = '';
    panelCompare.setAttribute('aria-pressed', 'false');
    panelCompare.textContent = 'Compare';
    controller?.clearCompare();
  }

  function renderCompareResult(
    from: string,
    to: string,
    path: import('../../lib/graph/pathfind').ComparePath | null,
  ): void {
    compareResult.hidden = false;
    compareResult.textContent = '';
    const fromTitle = controller?.getNode(from)?.title ?? from;
    const toTitle = controller?.getNode(to)?.title ?? to;
    const head = document.createElement('p');
    head.className = 'mono-note';
    if (!path || !path.found) {
      head.textContent = `NO TYPED PATH BETWEEN ${fromTitle.toUpperCase()} AND ${toTitle.toUpperCase()}`;
      compareResult.append(head);
      return;
    }
    head.textContent = `PATH // ${path.steps.length} ${path.steps.length === 1 ? 'HOP' : 'HOPS'}`;
    compareResult.append(head);
    const ol = document.createElement('ol');
    ol.className = 'galaxy-panel__path';
    for (const step of path.steps) {
      const li = document.createElement('li');
      const a = controller?.getNode(step.from)?.title ?? step.from;
      const b = controller?.getNode(step.to)?.title ?? step.to;
      const hop = document.createElement('span');
      hop.className = 'galaxy-panel__path-hop';
      hop.textContent = `${a} to ${b}`;
      const why = document.createElement('span');
      why.className = 'galaxy-panel__reason';
      why.textContent = step.reason;
      li.append(hop, why);
      ol.append(li);
    }
    compareResult.append(ol);
  }

  panelCompare.addEventListener('click', () => {
    if (compareArmed || panelCompare.textContent === 'Clear comparison') {
      exitCompareMode();
      return;
    }
    compareArmed = true;
    compareFrom = controller?.getSelectedSlug() ?? null;
    panelCompare.setAttribute('aria-pressed', 'true');
    panelCompare.textContent = 'Pick a project to compare';
    compareResult.hidden = false;
    compareResult.textContent = '';
    const hint = document.createElement('p');
    hint.className = 'mono-note';
    hint.textContent = 'SELECT A SECOND PROJECT TO TRACE THE PATH BETWEEN THEM';
    compareResult.append(hint);
  });

  // Sector filters (FR028-FR031): toggle buttons isolate sectors; the count
  // line reports visible projects; camera and selection survive filtering
  // unless the selection itself is hidden.
  const filterRail = document.getElementById('galaxy-filter-rail')!;
  const surpriseButton = document.getElementById(
    'galaxy-surprise',
  ) as HTMLButtonElement;
  const filterCount = document.getElementById('galaxy-filter-count')!;
  const activeSectors = new Set<string>();

  filterRail.addEventListener('click', (event) => {
    const btn = (event.target as HTMLElement).closest<HTMLButtonElement>(
      '[data-map-filter]',
    );
    if (!btn || !controller) return;
    const sector = btn.dataset.mapFilter!;
    if (activeSectors.has(sector)) activeSectors.delete(sector);
    else activeSectors.add(sector);
    btn.setAttribute('aria-pressed', String(activeSectors.has(sector)));
    const visible = controller.setSectorFilter(
      activeSectors.size ? activeSectors : null,
    );
    filterCount.textContent = activeSectors.size
      ? `${visible} PROJECTS VISIBLE`
      : '';
  });

  surpriseButton.addEventListener('click', () => {
    controller?.surpriseMe();
  });

  // ------------------------------------------------------------------
  // Command palette (FR023-FR027): Cmd-K, Ctrl-K, and / open it; it
  // searches projects, tours, and commands, and its own modal focus trap.
  // ------------------------------------------------------------------
  const palette = document.getElementById('galaxy-palette')!;
  const paletteInput = document.getElementById(
    'galaxy-palette-input',
  ) as HTMLInputElement;
  const paletteResults = document.getElementById('galaxy-palette-results')!;
  let paletteInvoker: HTMLElement | null = null;
  let paletteActive = -1;

  interface PaletteItem {
    label: string;
    hint: string;
    run: () => void;
  }

  function paletteCommands(): PaletteItem[] {
    if (!controller) return [];
    const items: PaletteItem[] = [];
    for (const node of controller.listNodes()) {
      items.push({
        label: node.title,
        hint: `PROJECT // ${node.sector.toUpperCase()}`,
        run: () => controller?.select(node.slug),
      });
    }
    for (const tour of controller.listTours()) {
      items.push({
        label: tour.title,
        hint: 'TOUR',
        run: () => startTour(tour.id),
      });
    }
    items.push(
      {
        label: 'Open Atlas',
        hint: 'COMMAND',
        run: () => (location.href = '/atlas/'),
      },
      {
        label: 'Surprise Me',
        hint: 'COMMAND',
        run: () => controller?.surpriseMe(),
      },
      {
        label: 'Reset View',
        hint: 'COMMAND',
        run: () => controller?.select(null),
      },
    );
    return items;
  }

  function renderPalette(query: string): void {
    const q = query.trim().toLowerCase();
    const all = paletteCommands();
    const matches = (
      q ? all.filter((i) => i.label.toLowerCase().includes(q)) : all
    ).slice(0, 8);
    paletteResults.textContent = '';
    paletteActive = matches.length ? 0 : -1;
    matches.forEach((item, i) => {
      const li = document.createElement('li');
      li.className = 'galaxy-palette__result';
      li.setAttribute('role', 'option');
      li.setAttribute('aria-selected', String(i === paletteActive));
      li.dataset.index = String(i);
      const label = document.createElement('span');
      label.textContent = item.label;
      const hint = document.createElement('span');
      hint.className = 'galaxy-palette__hint';
      hint.textContent = item.hint;
      li.append(label, hint);
      li.addEventListener('click', () => {
        item.run();
        closePalette();
      });
      paletteResults.append(li);
    });
    (paletteResults as HTMLElement).dataset.count = String(matches.length);
  }

  function openPalette(): void {
    if (stage.dataset.mapState !== 'online') return;
    paletteInvoker = (document.activeElement as HTMLElement) ?? null;
    palette.hidden = false;
    paletteInput.value = '';
    renderPalette('');
    paletteInput.focus();
  }

  function closePalette(): void {
    if (palette.hidden) return;
    palette.hidden = true;
    paletteInvoker?.focus();
  }

  paletteInput.addEventListener('input', () =>
    renderPalette(paletteInput.value),
  );

  paletteInput.addEventListener('keydown', (event) => {
    const options = Array.from(
      paletteResults.querySelectorAll<HTMLElement>('[role="option"]'),
    );
    if (event.key === 'ArrowDown') {
      event.preventDefault();
      paletteActive = Math.min(paletteActive + 1, options.length - 1);
    } else if (event.key === 'ArrowUp') {
      event.preventDefault();
      paletteActive = Math.max(paletteActive - 1, 0);
    } else if (event.key === 'Enter') {
      event.preventDefault();
      options[paletteActive]?.click();
      return;
    } else if (event.key === 'Escape') {
      event.preventDefault();
      closePalette();
      return;
    } else {
      return;
    }
    options.forEach((o, i) =>
      o.setAttribute('aria-selected', String(i === paletteActive)),
    );
    options[paletteActive]?.scrollIntoView({ block: 'nearest' });
  });

  palette.addEventListener('click', (event) => {
    if (event.target === palette) closePalette();
  });

  document.addEventListener('keydown', (event) => {
    const editing = editableTarget(event.target);
    if (
      (event.key === 'k' && (event.metaKey || event.ctrlKey)) ||
      (event.key === '/' && !editing)
    ) {
      event.preventDefault();
      if (palette.hidden) openPalette();
      else closePalette();
    }
  });

  // ------------------------------------------------------------------
  // Guided tours (FR039-FR043).
  // ------------------------------------------------------------------
  const tourBar = document.getElementById('galaxy-tour')!;
  const tourMeta = document.getElementById('galaxy-tour-meta')!;
  const tourNarration = document.getElementById('galaxy-tour-narration')!;
  const tourPrevBtn = document.getElementById(
    'galaxy-tour-prev',
  ) as HTMLButtonElement;
  const tourNextBtn = document.getElementById(
    'galaxy-tour-next',
  ) as HTMLButtonElement;
  const tourExitBtn = document.getElementById(
    'galaxy-tour-exit',
  ) as HTMLButtonElement;

  function startTour(id: string): void {
    closePalette();
    const url = new URL(location.href);
    url.searchParams.set('tour', id);
    history.replaceState(history.state, '', url);
    controller?.startTour(id);
  }

  tourPrevBtn.addEventListener('click', () => controller?.tourPrev());
  tourNextBtn.addEventListener('click', () => controller?.tourNext());
  tourExitBtn.addEventListener('click', () => {
    controller?.tourExit();
    const url = new URL(location.href);
    url.searchParams.delete('tour');
    history.replaceState(history.state, '', url);
  });

  // Deep link restore: applies after the scene reports online (AC016).
  function applyUrlSelection(): void {
    const slug = readSlugFromUrl();
    suppressUrlWrite = true;
    controller?.select(slug);
    suppressUrlWrite = false;
  }
  onSlugPop(() => applyUrlSelection());

  const onlineObserver = new MutationObserver(() => {
    if (stage.dataset.mapState === 'online') {
      onlineObserver.disconnect();
      // A tour deep link (?tour=) wins over a bare project link: it drives
      // its own selection sequence (FR043 shareable tour state).
      const tourId = new URLSearchParams(location.search).get('tour');
      if (tourId && controller?.listTours().some((t) => t.id === tourId)) {
        controller.startTour(tourId);
      } else if (readSlugFromUrl()) {
        applyUrlSelection();
      }
    }
  });
  onlineObserver.observe(stage, {
    attributes: true,
    attributeFilter: ['data-map-state'],
  });

  // Keyboard parity (AR003): arrows cycle stars, Enter confirms the cycled
  // star, Escape deselects and returns to overview. Document-level so the
  // aria-hidden canvas never needs to take focus; disabled while typing in
  // an editable control or when the map is not online.
  function editableTarget(t: EventTarget | null): boolean {
    return (
      t instanceof HTMLElement &&
      (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable)
    );
  }

  document.addEventListener('keydown', (event) => {
    if (stage.dataset.mapState !== 'online' || !controller) return;
    if (editableTarget(event.target)) return;
    if (event.key === 'Escape') {
      if (controller.getSelectedSlug()) {
        event.preventDefault();
        controller.select(null);
      }
      return;
    }
    if (event.key === 'ArrowRight' || event.key === 'ArrowLeft') {
      event.preventDefault();
      const order = controller.getKeyboardOrder();
      if (!order.length) return;
      const current = controller.getSelectedSlug();
      const idx = current ? order.indexOf(current) : -1;
      const step = event.key === 'ArrowRight' ? 1 : -1;
      const next = order[(idx + step + order.length) % order.length]!;
      controller.select(next);
    }
  });

  void boot();

  window.addEventListener('beforeunload', () => controller?.dispose());
</script>

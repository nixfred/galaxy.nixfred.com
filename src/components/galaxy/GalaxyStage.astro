---
// The single hydration island for the whole map (docs/ARCHITECTURE.md
// section 2, ADR-0001). Server-rendered output is inert: a canvas, a
// no-JS-required fallback link into Atlas, and the loading status FR002
// requires. No Three.js code ships with the initial page load; the inline
// bootstrap script below only performs a dynamic import() once WebGL
// support is confirmed (AC034, the lazy boundary). The canvas is aria-hidden
// decoration (docs/ACCESSIBILITY.md section 6): the Atlas route and the
// permanent ATLAS control here are the real accessible surface for the
// catalog, not this component.
---

<!--
  Two separate fixed layers, not one, because they need to sit on opposite
  sides of the hero shell in paint order and CSS stacking cannot straddle
  that from a single ancestor:
  - galaxy-backdrop (z-index: -1) paints behind the static hero content, so
    the canvas never covers the hero text.
  - galaxy-stage (no negative z-index; pointer-events: none at the container
    level with auto re-enabled per control, see global.css) paints above the
    hero so its controls stay reachable, while empty space around them still
    passes clicks through to the canvas beneath.
  A single wrapper with z-index: -1 would bury its *entire* subtree,
  including these controls, behind <body>'s own full-viewport box, which
  still intercepts pointer events even though it paints nothing there.
-->
<div class="galaxy-backdrop" id="galaxy-backdrop">
  <canvas
    class="galaxy-canvas"
    id="galaxy-canvas"
    aria-hidden="true"
    tabindex="-1"></canvas>
  <div class="galaxy-label-host" id="galaxy-label-host" aria-hidden="true">
  </div>
</div>

<div class="galaxy-stage" id="galaxy-stage" data-map-state="loading">
  <div class="galaxy-fallback" id="galaxy-fallback" hidden>
    <p class="mono-meta">Map unavailable on this device</p>
    <p class="hero-support">
      The interactive star map needs WebGL, which this browser or device does
      not currently support. The complete catalog is still fully available.
    </p>
    <a class="btn btn-primary" href="/atlas/">Open the Atlas</a>
  </div>

  <div class="galaxy-hud" id="galaxy-hud">
    <ul
      class="galaxy-boot-states"
      id="galaxy-boot-states"
      data-testid="galaxy-boot-states"
    >
      <li data-state="catalog-loading">Catalog loaded</li>
      <li data-state="renderer-ready">Renderer ready</li>
      <li data-state="labels-ready">Labels ready</li>
      <li data-state="online">Map online</li>
    </ul>
    <button
      type="button"
      class="btn btn-tertiary galaxy-skip"
      id="galaxy-skip"
      data-testid="galaxy-skip"
    >
      Skip
    </button>
  </div>

  <div class="galaxy-controls">
    <a
      class="btn btn-secondary galaxy-atlas-link"
      href="/atlas/"
      data-testid="galaxy-atlas-link"
    >
      Atlas
    </a>
    <button
      type="button"
      class="btn btn-secondary galaxy-pause"
      id="galaxy-pause"
      data-testid="galaxy-pause"
      aria-pressed="false"
      hidden
    >
      Pause Motion
    </button>
  </div>

  <p
    class="galaxy-readout mono-meta"
    id="galaxy-readout"
    data-testid="galaxy-readout"
    aria-hidden="true"
  >
  </p>

  <aside
    class="galaxy-panel"
    id="galaxy-panel"
    data-testid="galaxy-panel"
    aria-labelledby="galaxy-panel-title"
    hidden
  >
    <div class="galaxy-panel__grab" aria-hidden="true"></div>
    <p class="mono-meta galaxy-panel__status" id="galaxy-panel-status"></p>
    <h2 class="galaxy-panel__title" id="galaxy-panel-title"></h2>
    <p class="galaxy-panel__desc" id="galaxy-panel-desc"></p>
    <ul
      class="galaxy-panel__related"
      id="galaxy-panel-related"
      aria-label="Related projects"
    >
    </ul>
    <div class="galaxy-panel__actions">
      <a
        class="btn btn-primary"
        id="galaxy-panel-open"
        data-testid="panel-open-project"
        target="_blank"
        rel="noopener noreferrer">Open Project</a
      >
      <a class="btn btn-secondary" id="galaxy-panel-page" href="#"
        >Project Page</a
      >
      <button
        type="button"
        class="btn btn-tertiary"
        id="galaxy-panel-close"
        data-testid="panel-close">Close</button
      >
    </div>
  </aside>
</div>

<script>
  import type {
    GalaxyController as GalaxyControllerType,
    MapState,
  } from '../../lib/graph/controller';
  import {
    readSlugFromUrl,
    writeSlugToUrl,
    onSlugPop,
  } from '../../lib/state/deepLink';

  const stage = document.getElementById('galaxy-stage')!;
  const canvas = document.getElementById('galaxy-canvas') as HTMLCanvasElement;
  const fallback = document.getElementById('galaxy-fallback')!;
  const hud = document.getElementById('galaxy-hud')!;
  const bootStates = document.getElementById('galaxy-boot-states')!;
  const skipButton = document.getElementById(
    'galaxy-skip',
  ) as HTMLButtonElement;
  const pauseButton = document.getElementById(
    'galaxy-pause',
  ) as HTMLButtonElement;
  const readout = document.getElementById('galaxy-readout')!;
  const labelHost = document.getElementById('galaxy-label-host')!;
  const panel = document.getElementById('galaxy-panel')!;
  const panelStatus = document.getElementById('galaxy-panel-status')!;
  const panelTitle = document.getElementById('galaxy-panel-title')!;
  const panelDesc = document.getElementById('galaxy-panel-desc')!;
  const panelRelated = document.getElementById('galaxy-panel-related')!;
  const panelOpen = document.getElementById(
    'galaxy-panel-open',
  ) as HTMLAnchorElement;
  const panelPage = document.getElementById(
    'galaxy-panel-page',
  ) as HTMLAnchorElement;
  const panelClose = document.getElementById(
    'galaxy-panel-close',
  ) as HTMLButtonElement;

  const reducedMotionQuery = window.matchMedia(
    '(prefers-reduced-motion: reduce)',
  );

  function detectWebgl(): boolean {
    try {
      const probe = document.createElement('canvas');
      return Boolean(
        probe.getContext('webgl2') ||
        probe.getContext('webgl') ||
        probe.getContext('experimental-webgl'),
      );
    } catch {
      return false;
    }
  }

  function showFallback(): void {
    stage.dataset.mapState = 'fallback';
    canvas.style.display = 'none';
    hud.style.display = 'none';
    fallback.hidden = false;
  }

  function hideEntranceOverlay(instant: boolean): void {
    const delay = instant || reducedMotionQuery.matches ? 0 : 450;
    window.setTimeout(() => {
      bootStates.classList.add('is-dismissed');
      skipButton.hidden = true;
    }, delay);
  }

  let controller: GalaxyControllerType | null = null;

  async function boot(): Promise<void> {
    if (!detectWebgl()) {
      showFallback();
      return;
    }

    skipButton.addEventListener('click', () => {
      controller?.skipEntrance();
      hideEntranceOverlay(true);
    });

    // "ENTER THE MAP" in the hero shell dismisses the entrance chrome too;
    // it is a real action now rather than a dead link into a future phase.
    for (const el of document.querySelectorAll('[data-action="enter-map"]')) {
      el.addEventListener('click', (event) => {
        event.preventDefault();
        controller?.skipEntrance();
        hideEntranceOverlay(true);
      });
    }

    pauseButton.addEventListener('click', () => {
      const paused = pauseButton.getAttribute('aria-pressed') === 'true';
      pauseButton.setAttribute('aria-pressed', String(!paused));
      controller?.setMotionPaused(!paused);
    });

    reducedMotionQuery.addEventListener('change', (event) => {
      controller?.setReducedMotion(event.matches);
    });

    try {
      const { GalaxyController } = await import('../../lib/graph/controller');
      controller = new GalaxyController();
      await controller.init(canvas, {
        labelHost,
        reducedMotion: reducedMotionQuery.matches,
        onStateChange: (state: MapState) => {
          stage.dataset.mapState = state;
          const item = bootStates.querySelector(`[data-state="${state}"]`);
          item?.classList.add('is-done');
          if (state === 'renderer-ready') pauseButton.hidden = false;
          if (state === 'online') hideEntranceOverlay(false);
        },
        onHover: (change) => {
          if (change.slug) readout.textContent = `HOVER // ${change.slug}`;
          else if (!readout.dataset.selected) readout.textContent = '';
        },
        onSelect: (change) => {
          readout.dataset.selected = change.slug ?? '';
          readout.textContent = change.slug ? `SELECTED // ${change.slug}` : '';
          applySelection(change.slug);
        },
        onFallback: () => showFallback(),
      });
    } catch {
      showFallback();
    }
  }

  // ------------------------------------------------------------------
  // Selection panel, deep links, history, and keyboard (Phase 3b:
  // FR015-FR022, AC015, AC016, AR003, AR004).
  // ------------------------------------------------------------------
  let lastInvoker: HTMLElement | null = null;
  let suppressUrlWrite = false;

  function applySelection(slug: string | null): void {
    if (!suppressUrlWrite) writeSlugToUrl(slug);
    if (!slug) {
      if (!panel.hidden) {
        panel.hidden = true;
        // AR004: focus returns to the initiating control when the panel
        // closes; the canvas region is not focusable, so fall back to the
        // Atlas control which is always visible.
        (
          lastInvoker ??
          document.querySelector<HTMLElement>(
            '[data-testid="galaxy-atlas-link"]',
          )
        )?.focus();
      }
      return;
    }
    const node = controller?.getNode(slug);
    if (!node) return;
    const edges = controller?.getEdgesFor(slug) ?? [];

    const statusParts = [`SECTOR: ${node.sector.toUpperCase()}`];
    if (node.status) statusParts.push(`STATUS: ${node.status.toUpperCase()}`);
    if (node.anchor) statusParts.push('ANCHOR');
    statusParts.push(`REL: ${edges.length}`);
    panelStatus.textContent = statusParts.join(' // ');
    panelTitle.textContent = node.title;
    panelDesc.textContent = node.desc;
    panelOpen.href = node.url;
    panelPage.href = `/project/${node.slug}/`;

    panelRelated.textContent = '';
    for (const edge of edges) {
      const otherSlug = edge.source === slug ? edge.target : edge.source;
      const other = controller?.getNode(otherSlug);
      if (!other) continue;
      const li = document.createElement('li');
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'galaxy-panel__related-link';
      btn.textContent = other.title;
      btn.addEventListener('click', () => controller?.select(otherSlug));
      const reason = document.createElement('span');
      reason.className = 'galaxy-panel__reason';
      reason.textContent = edge.reason ?? '';
      li.append(btn, reason);
      panelRelated.append(li);
    }

    const wasHidden = panel.hidden;
    panel.hidden = false;
    if (wasHidden) {
      lastInvoker = (document.activeElement as HTMLElement) ?? null;
      // AR004: focus moves into the panel when it opens.
      panelClose.focus();
    }
  }

  panelClose.addEventListener('click', () => controller?.select(null));

  // Deep link restore: applies after the scene reports online (AC016).
  function applyUrlSelection(): void {
    const slug = readSlugFromUrl();
    suppressUrlWrite = true;
    controller?.select(slug);
    suppressUrlWrite = false;
  }
  onSlugPop(() => applyUrlSelection());

  const onlineObserver = new MutationObserver(() => {
    if (stage.dataset.mapState === 'online') {
      onlineObserver.disconnect();
      if (readSlugFromUrl()) applyUrlSelection();
    }
  });
  onlineObserver.observe(stage, {
    attributes: true,
    attributeFilter: ['data-map-state'],
  });

  // Keyboard parity (AR003): arrows cycle stars, Enter confirms the cycled
  // star, Escape deselects and returns to overview. Document-level so the
  // aria-hidden canvas never needs to take focus; disabled while typing in
  // an editable control or when the map is not online.
  function editableTarget(t: EventTarget | null): boolean {
    return (
      t instanceof HTMLElement &&
      (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable)
    );
  }

  document.addEventListener('keydown', (event) => {
    if (stage.dataset.mapState !== 'online' || !controller) return;
    if (editableTarget(event.target)) return;
    if (event.key === 'Escape') {
      if (controller.getSelectedSlug()) {
        event.preventDefault();
        controller.select(null);
      }
      return;
    }
    if (event.key === 'ArrowRight' || event.key === 'ArrowLeft') {
      event.preventDefault();
      const order = controller.getKeyboardOrder();
      if (!order.length) return;
      const current = controller.getSelectedSlug();
      const idx = current ? order.indexOf(current) : -1;
      const step = event.key === 'ArrowRight' ? 1 : -1;
      const next = order[(idx + step + order.length) % order.length]!;
      controller.select(next);
    }
  });

  void boot();

  window.addEventListener('beforeunload', () => controller?.dispose());
</script>

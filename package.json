{
  "name": "galaxy.nixfred.com",
  "version": "0.1.0",
  "description": "NIXFRED GALAXY: every project, one connected system. Interactive star map of Fred Nix's public body of work.",
  "type": "module",
  "private": true,
  "homepage": "https://galaxy.nixfred.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/nixfred/galaxy.nixfred.com"
  },
  "license": "MIT",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "astro:check": "astro check",
    "data:sync": "bun run scripts/sync-catalog.ts",
    "data:validate": "bun run scripts/validate-catalog.ts && bun run scripts/validate-graph.ts",
    "data:census": "bun run scripts/domain-census.ts",
    "test": "bun run test:unit",
    "test:unit": "vitest run",
    "test:e2e": "playwright test --project=e2e",
    "test:a11y": "playwright test --project=a11y",
    "test:visual": "playwright test --project=visual",
    "test:performance": "playwright test --project=performance",
    "check:links": "bun run scripts/check-links.ts",
    "check:all": "bun run format:check && bun run lint && bun run typecheck && bun run astro:check && bun run data:validate && bun run test:unit && bun run build && bun run scripts/report-bundle.ts && bun run check:links"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.7",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "@types/three": "^0.185.1",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^2.1.1",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  }
}
